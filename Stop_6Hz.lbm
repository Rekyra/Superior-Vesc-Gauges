(gpio-configure 'pin-ppm 'pin-mode-out)
(gpio-write 'pin-ppm 1)

(loopwhile t
  (progn
    (def v (get-adc 1))

    ; === HAMOWANIE: MIGANIE 3 Hz TYLKO PRZY > 0.9V ===
    (if (> v 0.91)
        (progn
          (gpio-write 'pin-ppm 1)
          (sleep 0.0833)   ; ~166 ms WŁ
          (gpio-write 'pin-ppm 0)
          (sleep 0.0833))  ; ~166 ms WYŁ
        ; === BRAK HAMOWANIA LUB < 0.9V: ŚWIECENIE CIĄGŁE ===
        (gpio-write 'pin-ppm 1))

    (sleep 0.05)))  ; Szybka reakcja na hamulec